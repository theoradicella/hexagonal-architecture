meta {
  name: List Vendors
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/vendors?page=1&page_size=10
  auth: none
}

headers {
  Authorization: Bearer {{token}}
}

params:query {
  page: 1
  page_size: 10
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });
}
